# StackGen AI Agent - Environment Configuration
# Copy this file to `.env` and fill in your actual credentials.

# ──────────────────────────────────────────────────────
# User Integrations configuration
# ──────────────────────────────────────────────────────
GITHUB_USER1_USERNAME=bob_github_username
GITHUB_USER1_TOKEN=ghp_exampletokenforbob...
LINEAR_USER1_TOKEN=lin_api_exampletokenforbob...
USER1_NAME=Bob

GITHUB_USER2_USERNAME=alice_github_username
GITHUB_USER2_TOKEN=ghp_exampletokenforalice...
LINEAR_USER2_TOKEN=lin_api_exampletokenforalice...
USER2_NAME=Alice

# -- Additional Users (Optional) --
# You can add more users by adding more tokens and usernames in sequence (USER3, USER4...)
# GITHUB_USER3_USERNAME=charlie_github_username
# GITHUB_USER3_TOKEN=ghp_exampletokenforcharlie...
# LINEAR_USER3_TOKEN=lin_api_exampletokenforcharlie...
# USER3_NAME=Charlie

# ──────────────────────────────────────────────────────
# LLM Configuration (pick ONE, uncomment & set key)
# ──────────────────────────────────────────────────────

# Option 1: Local Ollama (Default, no API key needed)
OLLAMA_MODEL=llama3.2:3b
# For local native execution, use http://localhost:11434
# For Docker execution, use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Option 2: OpenAI
# If you prefer to use OpenAI (e.g., GPT-4o) instead of the local Ollama instance,
# simply provide your API key below. The system will automatically bypass Ollama.
# OPENAI_API_KEY=sk-proj-youropenaikeyhere...
# OPENAI_MODEL=gpt-4o-mini
CREWAI_TELEMETRY_OPT_OUT=true
